class PyHydra:
    def __init__(self):
        self.colors = Colors()
        self.logger = Logger()
        self.found = False
        self.found_password = None
        self.attempts = 0
        self.lock = threading.Lock()
        self.start_time = None
        self.shutdown_flag = threading.Event()
        
        self.modules = {
            'ftp': FTPCracker,
            'ssh': SSHCracker,
            'http': HTTPCracker,
            'http-get': HTTPCracker,
            'mysql': MySQLCracker
        }
    
